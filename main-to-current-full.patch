new file mode 100644
index 0000000..1206cbf
--- /dev/null
+++ b/domain/traitAttributeLimits.test.js
@@ -0,0 +1,54 @@
+import { describe, it, expect } from 'vitest';
+import { getAttributeLimits, getTraitAttributeBonus, getRemainingAttributePoints, createInitialAttributes } from './characterCreation.js';
+
+// Post-v1.5 shape: attributeBonus + attributeLimits at top level of modifiers.
+// Bonus and limits are independent — a trait may grant only one or both.
+const superMutant = {
+  modifiers: {
+    attributeBonus:  { STR: 2, END: 2 },
+    attributeLimits: { STR: { min: 6, max: 12 }, END: { min: 6, max: 12 }, CHA: { max: 6 }, INT: { max: 6 } },
+  },
+};
+
+describe('trait attribute limits/bonus (post-v1.5 split)', () => {
+  it('reads min/max from attributeLimits.{X}', () => {
+    expect(getAttributeLimits(superMutant, 'STR')).toEqual({ min: 6, max: 12 });
+    expect(getAttributeLimits(superMutant, 'END')).toEqual({ min: 6, max: 12 });
+    // only max declared → min falls back to base 4
+    expect(getAttributeLimits(superMutant, 'CHA')).toEqual({ min: 4, max: 6 });
+  });
+
+  it('no trait → base limits 4..10', () => {
+    expect(getAttributeLimits(null, 'STR')).toEqual({ min: 4, max: 10 });
+  });
+
+  it('getTraitAttributeBonus reads attributeBonus.{X}', () => {
+    expect(getTraitAttributeBonus('STR', superMutant)).toBe(2);
+    expect(getTraitAttributeBonus('END', superMutant)).toBe(2);
+    // bonus absent for this attribute → 0
+    expect(getTraitAttributeBonus('CHA', superMutant)).toBe(0);
+  });
+
+  it('negative bonus allowed (penalty)', () => {
+    const trait = { modifiers: { attributeBonus: { STR: -1 } } };
+    expect(getTraitAttributeBonus('STR', trait)).toBe(-1);
+  });
+
+  it('getRemainingAttributePoints returns a finite number', () => {
+    const pts = getRemainingAttributePoints(createInitialAttributes(), superMutant);
+    expect(typeof pts).toBe('number');
+    expect(Number.isNaN(pts)).toBe(false);
+  });
+
+  it('legacy minLimits/maxLimits/attributes.{X} shapes are NOT supported anymore', () => {
+    const legacyTrait = {
+      modifiers: {
+        minLimits: { STR: 5 },
+        maxLimits: { STR: 9 },
+        attributes: { STR: { baseBonus: 2, min: 6, max: 12 } },
+      },
+    };
+    // legacy shapes are ignored; only attributeLimits counts.
+    expect(getAttributeLimits(legacyTrait, 'STR')).toEqual({ min: 4, max: 10 });
+  });
+});
