+  // an explicit origin.bodyPlan.
   const originId = character?.origin?.id;
   if (originId && ROBOT_ORIGIN_TO_PLAN[originId] && bodyPlansRegistry[ROBOT_ORIGIN_TO_PLAN[originId]]) {
     return ROBOT_ORIGIN_TO_PLAN[originId];
